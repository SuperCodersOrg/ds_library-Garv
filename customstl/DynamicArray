#pragma once

#include <iostream>
using namespace std;

template <typename T>
class DynamicArray {
private:
    int size_;
    int capacity_;
    T *data;
    void resize(int newCapacity)
    {
        if(newCapacity<size_)return;

        T* arr = new T[newCapacity];

        for(int i = 0; i < size_; i++)
        {
            arr[i] = data[i];
        }

        delete[] data;

        data = arr;
        capacity_ = newCapacity;
    }
public:
    DynamicArray(int cap=0){
        size_=0;
        capacity_=cap;
        data=nullptr;
    }

    template <typename Iterator>
    DynamicArray(Iterator start,Iterator end)
    {
        
    }

    void append(const T& value){
        //resize
        if(size_==capacity_)resize(capacity_==0?1:capacity_*2);
        //normally
        data[size_++]=value;
    }

    void insert(const T& value,int index)
    {
        //indexcheck
        if(index<0 || index>size_)
        {
            cout<< "Error - Invalid Index"<<endl;
            return;
        }
        if(size_==capacity_)
        {
            resize(capacity_ == 0 ? 1 : capacity_ * 2);
        }
        for(int i=size_;i>index;i--)
        {
            data[i]=data[i-1];
        }
        data[index]=value;
        size_++;
    }

    void remove(int index)
    {
        if(index<0 || index>=size_)
        {
            cout<< "Error - Invalid Index"<<endl;
            return;
        }
        for(int i=index;i<size_-1;i++)
        {
            data[i]=data[i+1];
        }
        size_--;
        if(capacity_>1 && size_<=capacity_/4)
        resize(capacity_/2);
    }
    
    //testing purpose
    void print()const
    {
        for(int i=0;i<size_;i++)
        {
            cout<<data[i]<<" ";
        }
    }

    ~DynamicArray()
    {
        delete[] data;
        capacity_=0;
        size_=0;
    }
};
