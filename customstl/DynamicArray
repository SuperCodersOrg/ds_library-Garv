#pragma once

#include <iostream>
using namespace std;

class DynamicArray {
private:
    int size;
    int capacity;
    int *data;
public:

    DynamicArray(){
        size = 0;
        capacity = 0;
        data = nullptr;
    }

    void append(int value){
        //if capacity 0
        if(capacity==0)
        {
            capacity=1;
            data = new int [capacity];
        }
        //if full
        if(size==capacity)
        {
            int oldcapacity = capacity;
            capacity*=2;
            int *arr = new int [capacity];
            for(int i=0;i<size;i++)
            {
                arr[i]=data[i];
            }
            delete []data;
            data = arr;
        }
        //normally
        data[size++]=value;
    }

    void insert(int value,int index)
    {
        //indexcheck
        if(index<0 || index>size)
        {
            cout<< "Error - Invalid Index";
        }
        //if capacity 0
        if(capacity==0)
        {
            capacity=1;
            data = new int [capacity];
        }
        //if full
        if(size==capacity)
        {
            capacity*=2;
            int *arr = new int [capacity];

            for(int i=0;i<index;i++)
            {
                arr[i]=data[i];
            }
            for(int i=index;i<size;i++)
            {
                arr[i+1]=data[i];
            }
            delete []data;
            data = arr;
        }
        else
        {
            for(int i=size;i>index;i--)
            {
                data[i]=data[i-1];
            }
        }
        data[index]=value;
        size++;
    }

    //testing purpose
    void print()
    {
        for(int i=0;i<size;i++)
        {
            cout<<data[i]<<" ";
        }
    }
};